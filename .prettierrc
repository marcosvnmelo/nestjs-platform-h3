{
  "singleQuote": true,
  "quoteProps": "consistent",
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "<TYPES>",
    "<THIRD_PARTY_MODULES>",
    "",
    "<TYPES>^@nestjs",
    "^@nestjs/(.*)$",
    "",
    "<TYPES>^@marcosvnmelo",
    "^@marcosvnmelo/(.*)$",
    "",
    "<TYPES>^[#](([a-z]|[-])+)?",
    "<TYPES>^([.]{1,2}|~|@)/",
    "^[#](([a-z]|[-])+)?",
    "^([.]{1,2}|~|@)/"
  ],
  "importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
  "importOrderTypeScriptVersion": "4.4.0"
}
