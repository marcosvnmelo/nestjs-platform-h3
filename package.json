{
  "name": "@marcosvnmelo/nestjs-platform-h3",
  "description": "A H3 adapter for NestJS framework",
  "version": "11.1.19-1",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcosvnmelo/nestjs-platform-h3"
  },
  "keywords": [
    "typescript",
    "library",
    "nestjs",
    "h3",
    "platform"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapter/utils": {
      "types": "./dist/adapters/utils/index.d.ts",
      "import": "./dist/adapters/utils/index.js",
      "default": "./dist/adapters/utils/index.js"
    }
  },
  "testExports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapter/utils": {
      "types": "./src/adapters/utils/index.ts",
      "import": "./src/adapters/utils/index.ts",
      "default": "./src/adapters/utils/index.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "rslib build --watch",
    "build": "rslib build",
    "benchmark": "pnpm --filter @marcosvnmelo/nestjs-platform-h3-benchmark run benchmark",
    "typecheck": "tsc --noEmit",
    "typecheck:workspace": "pnpm --filter ...* typecheck",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm --filter ...* run test",
    "test:watch": "pnpm --filter ...* run test:watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "quick-publish"
  },
  "dependencies": {
    "@fastify/busboy": "catalog:",
    "@types/content-type": "catalog:",
    "@types/mime-types": "catalog:",
    "content-type": "catalog:",
    "h3": "catalog:",
    "mime-types": "catalog:",
    "path-to-regexp": "catalog:",
    "rxjs": "catalog:",
    "srvx": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@microsoft/api-extractor": "^7.58.2",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/adapter-rslib": "catalog:",
    "@rstest/core": "catalog:",
    "@types/node": "catalog:",
    "eslint": "10.2.0",
    "prettier": "3.8.2",
    "quick-publish": "0.7.1",
    "typescript": "catalog:",
    "typescript-eslint": "8.58.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  }
}
