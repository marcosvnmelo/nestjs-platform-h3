{
  "name": "@marcosvnmelo/source",
  "description": "A H3 adapter for NestJS framework",
  "version": "11.1.19-1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @marcosvnmelo/nestjs-platform-h3 run dev",
    "build": "pnpm --filter @marcosvnmelo/nestjs-platform-h3 run build",
    "benchmark": "pnpm --filter @marcosvnmelo/nestjs-platform-h3-benchmark run benchmark",
    "test": "pnpm --filter ...* run test",
    "test:watch": "pnpm --filter ...* run test:watch",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "pnpm --filter ...* run lint",
    "lint:fix": "pnpm --filter ...* run lint:fix",
    "typecheck": "pnpm --filter ...* typecheck",
    "release": "pnpm test && pnpm lint && pnpm format && pnpm --filter @marcosvnmelo/nestjs-platform-h3 run release"
  },
  "dependencies": {
    "@fastify/busboy": "catalog:",
    "@types/content-type": "catalog:",
    "@types/mime-types": "catalog:",
    "content-type": "catalog:",
    "h3": "catalog:",
    "mime-types": "catalog:",
    "path-to-regexp": "catalog:",
    "rxjs": "catalog:",
    "srvx": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@microsoft/api-extractor": "^7.58.2",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/adapter-rslib": "catalog:",
    "@rstest/core": "catalog:",
    "@types/node": "catalog:",
    "eslint": "10.2.0",
    "prettier": "3.8.2",
    "quick-publish": "0.7.1",
    "typescript": "catalog:",
    "typescript-eslint": "8.58.2"
  }
}
